rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function diff() {
      return request.resource.data.diff(resource.data);
    }

    // ── User profile field validators ────────────────────
    // Each validator follows the same pattern:
    //   "field is either NOT being changed, OR the new value is valid"
    //
    // Without these checks, a user with a stolen Firebase ID token could
    // write directly via the Firestore client SDK (bypassing our server
    // API) and stuff arbitrary bytes into displayName / trackColor / etc.
    // Our server-side validation in /api/users/me/* would be irrelevant.

    function isDisplayNameValid() {
      return !diff().affectedKeys().hasAny(['displayName'])
        || (request.resource.data.displayName is string
            && request.resource.data.displayName.size() >= 2
            && request.resource.data.displayName.size() <= 60);
    }

    function isTrackColorValid() {
      return !diff().affectedKeys().hasAny(['trackColor'])
        || (request.resource.data.trackColor is string
            && request.resource.data.trackColor.matches('^#[0-9a-fA-F]{6}$'));
    }

    function isPhotoURLValid() {
      return !diff().affectedKeys().hasAny(['photoURL'])
        || request.resource.data.photoURL == null
        || (request.resource.data.photoURL is string
            && request.resource.data.photoURL.size() <= 2048);
    }

    function isUpdatedAtValid() {
      return !diff().affectedKeys().hasAny(['updatedAt'])
        || request.resource.data.updatedAt is timestamp;
    }

    function isRoleValid() {
      return !diff().affectedKeys().hasAny(['role'])
        || (request.resource.data.role in
            ['admin', 'editor', 'writer', 'reviewer', 'proofreader', 'viewer']);
    }

    function isStatusValid() {
      return !diff().affectedKeys().hasAny(['status'])
        || (request.resource.data.status in
            ['pending', 'active', 'rejected', 'disabled']);
    }

    // ── Users ────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // self update — limited fields + values validated
      allow update: if isOwner(uid)
        && diff().affectedKeys()
          .hasOnly(['trackColor', 'displayName', 'photoURL', 'updatedAt'])
        && isDisplayNameValid()
        && isTrackColorValid()
        && isPhotoURLValid()
        && isUpdatedAtValid();

      // admin update — can also change role + status; values validated
      allow update: if isAdmin()
        && diff().affectedKeys()
          .hasOnly(['role', 'status', 'trackColor', 'displayName', 'photoURL', 'updatedAt'])
        && isDisplayNameValid()
        && isTrackColorValid()
        && isPhotoURLValid()
        && isUpdatedAtValid()
        && isRoleValid()
        && isStatusValid();

      // create/delete only via server (admin SDK)
      allow create, delete: if false;
    }

    // ── Invites (admin → new user) ───────────────────────
    // All read/write via server (admin SDK bypasses these rules).
    // Public /register endpoint reads via server with token verification.
    match /invites/{token} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Password reset tokens (admin → existing user) ────
    // Same model as invites: admin reads, all writes via server.
    // Public /reset-password endpoint reads via server with token check.
    match /passwordResets/{token} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Auth events (audit log) ──────────────────────────
    match /authEvents/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Projects ─────────────────────────────────────────
    // Defense-in-depth: rules only allow admin or owner direct access.
    // Members read via server (which checks projectMembers).
    // All writes go through server (admin SDK bypasses).
    match /projects/{projectId} {
      allow read: if isAdmin()
        || (resource.data.ownerUid == request.auth.uid);
      allow create, update, delete: if false; // server-only
    }

    // ── Project members ──────────────────────────────────
    // User can read their own membership (to see "my projects").
    // Owner can read all members of their project.
    // Writes only via server.
    match /projectMembers/{memberId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid
        || isAdmin()
        || (exists(/databases/$(database)/documents/projects/$(resource.data.projectId))
            && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerUid == request.auth.uid)
      );
      allow create, update, delete: if false;
    }

    // ── Outlines (Phase 1 AI content generation) ─────────
    // Sub-collection under each project — Q1=A means exactly one
    // outline doc per project (id="current"). Sub-collection (vs a
    // field on the project doc) keeps it easy to add history /
    // multiple outlines later without a migration.
    //
    // All client reads + writes go through /api/projects/[id]/outline/*
    // which uses the admin SDK (and enforces member access). Clients
    // don't talk to Firestore directly for outlines.
    match /projects/{projectId}/outline/{outlineId} {
      allow read, write: if false;
    }

    // ── Tone library (Phase 1.5) ─────────────────────────
    // Per-editor writing-style samples + analysed style profile.
    // Owner-scoped permission (owner OR admin) is enforced server-side
    // in /api/tones/* — Firestore rules just block direct client
    // access because the membership logic (ownerUid + admin role
    // check across separate users collection) doesn't fit cleanly in
    // rules syntax and we don't gain much by duplicating it.
    match /tones/{toneId} {
      allow read, write: if false;
    }
    match /tones/{toneId}/samples/{sampleId} {
      allow read, write: if false;
    }
  }
}
