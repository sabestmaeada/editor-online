rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function diff() {
      return request.resource.data.diff(resource.data);
    }

    // ── Users ────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // self update — limited fields only
      allow update: if isOwner(uid)
        && diff().affectedKeys()
          .hasOnly(['trackColor', 'displayName', 'photoURL', 'updatedAt']);

      // admin update — can also change role
      allow update: if isAdmin()
        && diff().affectedKeys()
          .hasOnly(['role', 'trackColor', 'displayName', 'photoURL', 'updatedAt']);

      allow create, delete: if false;
    }

    // ── Auth events (audit log) ──────────────────────────
    match /authEvents/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Projects ─────────────────────────────────────────
    // Defense-in-depth: rules only allow admin or owner direct access.
    // Members read via server (which checks projectMembers).
    // All writes go through server (admin SDK bypasses).
    match /projects/{projectId} {
      allow read: if isAdmin()
        || (resource.data.ownerUid == request.auth.uid);
      allow create, update, delete: if false; // server-only
    }

    // ── Project members ──────────────────────────────────
    // User can read their own membership (to see "my projects").
    // Owner can read all members of their project.
    // Writes only via server.
    match /projectMembers/{memberId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid
        || isAdmin()
        || (exists(/databases/$(database)/documents/projects/$(resource.data.projectId))
            && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerUid == request.auth.uid)
      );
      allow create, update, delete: if false;
    }
  }
}
