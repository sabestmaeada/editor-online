# ─────────────────────────────────────────────────────────────
# Firebase Web SDK (client) — public, safe to expose to browser
# Source: Firebase Console → Project Settings → Your apps → Web
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────
# Firebase Admin SDK (server) — SECRET, never expose to browser
# Source: Firebase Console → Project Settings → Service accounts
#         → Generate new private key → download JSON
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Wrap the entire key (incl. BEGIN/END lines) in double quotes.
# Keep the literal \n escape sequences — code converts them at runtime.
FIREBASE_PRIVATE_KEY=""

# ─────────────────────────────────────────────────────────────
# Audit logging — IP hash pepper (server only, SECRET)
# Generate with: openssl rand -hex 32
# Must stay STABLE across deploys (rotating invalidates old hashes)
# ─────────────────────────────────────────────────────────────
IP_HASH_PEPPER=
